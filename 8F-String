#placeholders
#To format values in an f-string,
# add placeholders {}, a placeholder can 
# contain variables, operations, functions,
#  and modifiers to format the value.
price2 = 49.99
txt2 = f"The price is {price2} dollars"
print(txt2)
# -> The price is 49.99 dollars

#A placeholder can also include a modifier
# to format the value.
# A modifier is included by adding a colon :
# followed by a legal formatting type,
# like .2f which means fixed point number with 2 decimals.
price3 = 12
txt3 = f"The price is {price3:.2f} dollars"
print(txt3) # -> The price is 12.00 dollars

#You can also format a value directly 
# without keeping it in a variable.
txt4 = f"The price is {42:.2f} dollars"
print(txt4) # -> The price is 42.00 dollars

