#Multiple Methods
class Rectangle:
  def __init__(self, width, height):
    self.width = width
    self.height = height

  def area(self):
    return self.width * self.height

  def perimeter(self):
    return 2 * (self.width + self.height)
rect1 = Rectangle(4, 2)
print(rect1.area()) #-> 8
print(rect1.perimeter()) #-> 12

class Playlist:
  def __init__(self, name):
    self.name = name
    # initially, the playlist has no songs,
    # so we create an empty list to store them.
    self.songs = [] 

    #append() method is used to add an item to
    # the end of a list.
  def add_song(self, song):
    self.songs.append(song)
    print(f"Added: {song}")

  def remove_song(self, song):
    if song in self.songs:
      self.songs.remove(song)
      print(f"Removed: {song}")

  def show_songs(self):
    print(f"Playlist '{self.name}':")
    for song in self.songs:
      print(f"- {song}")

my_playlist = Playlist("Favorites")
my_playlist.add_song("Bohemian Rhapsody") #-> Added: Bohemian Rhapsody
my_playlist.add_song("Stairway to Heaven") #-> Added: Stairway to Heaven
my_playlist.show_songs() #-> Playlist 'Favorites':
                        #-> - Bohemian Rhapsody
                        #-> - Stairway to Heaven

