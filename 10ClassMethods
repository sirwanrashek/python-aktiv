#Methods Accessing Properties
class Circle:
  def __init__(self, radius):
    self.radius = radius
  def area(self):
    # 5 ** 2 = 25 * 3.14 = 78.5
    return 3.14 * self.radius ** 2  
circle1 = Circle(5)
print(circle1.area()) #-> 78.5
 
#Methods can access properties using the self keyword,
# which refers to the instance of the class.
#f-strings can be used to format 
# the output of methods that access properties:
class Person:
  def __init__(self, name, age):
    self.name = name
    self.age = age

  def get_info(self):
    return f"{self.name} is {self.age} years old"

p1 = Person("Tobias", 28)
print(p1.get_info()) 
#-> Tobias is 28 years old

class Person:
  def __init__(self, name, age):
    self.name = name
    self.age = age

  def birthday(self):
    self.age += 1 #modify Properties
    return f"Happy Birthday {self.name}! You are now {self.age} years old."
p1 = Person("Tobias", 29) 
print(p1.birthday()) 
#-> Happy Birthday Tobias!You are now 30 years old.

#the __str__() method defines how an object
# is represented as a string.
# in anther word is a special method that controls 
# what is returned when the object is printed:
class Car:
  def __init__(self, make, model):
    self.make = make
    self.model = model

  def __str__(self):
    return f"{self.make} {self.model}"
car1 = Car("Honda", "Civic")
